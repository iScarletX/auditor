{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://butler.local/schemas/review-report.v2.schema.json",
  "title": "ReviewReport",
  "type": "object",
  "required": ["meta", "issues", "consolidation", "summary"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["target_sp_hash", "scenario_hint", "skills_run", "models_used", "timestamp"],
      "additionalProperties": false,
      "properties": {
        "target_sp_hash": { "type": "string" },
        "scenario_hint": { "type": "string" },
        "skills_run": { "type": "array", "items": { "type": "string" } },
        "models_used": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" },
        "review_duration_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "issues": {
      "type": "array",
      "items": { "$ref": "#/definitions/Issue" }
    },
    "consolidation": { "$ref": "#/definitions/ReviewConsolidation" },
    "summary": {
      "type": "object",
      "required": [
        "overall_score",
        "issue_count_by_severity",
        "issue_count_by_category",
        "not_applicable_count"
      ],
      "additionalProperties": false,
      "properties": {
        "overall_score": { "type": "number", "minimum": 0, "maximum": 100 },
        "issue_count_by_severity": {
          "type": "object",
          "required": ["critical", "major", "minor", "info"],
          "additionalProperties": false,
          "properties": {
            "critical": { "type": "integer", "minimum": 0 },
            "major": { "type": "integer", "minimum": 0 },
            "minor": { "type": "integer", "minimum": 0 },
            "info": { "type": "integer", "minimum": 0 }
          }
        },
        "issue_count_by_category": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "clarity": { "type": "integer", "minimum": 0 },
            "contract": { "type": "integer", "minimum": 0 },
            "resource": { "type": "integer", "minimum": 0 },
            "interop": { "type": "integer", "minimum": 0 },
            "robustness": { "type": "integer", "minimum": 0 },
            "quality": { "type": "integer", "minimum": 0 },
            "compliance": { "type": "integer", "minimum": 0 }
          }
        },
        "not_applicable_count": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "definitions": {
    "ReviewConsolidation": {
      "type": "object",
      "required": ["has_new_findings", "new_issues", "conflict_notes", "systemic_findings"],
      "additionalProperties": false,
      "properties": {
        "has_new_findings": { "type": "boolean" },
        "new_issues": {
          "type": "array",
          "items": { "$ref": "#/definitions/Issue" }
        },
        "conflict_notes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["issue_ids", "description", "recommendation"],
            "additionalProperties": false,
            "properties": {
              "issue_ids": { "type": "array", "items": { "type": "string" } },
              "description": { "type": "string" },
              "recommendation": { "type": "string" }
            }
          }
        },
        "systemic_findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["related_issue_ids", "description", "severity"],
            "additionalProperties": false,
            "properties": {
              "related_issue_ids": { "type": "array", "items": { "type": "string" } },
              "description": { "type": "string" },
              "severity": { "$ref": "#/definitions/IssueSeverity" }
            }
          }
        }
      }
    },
    "Issue": {
      "type": "object",
      "required": [
        "id",
        "skill_id",
        "category",
        "status",
        "location",
        "description",
        "fix"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "skill_id": { "type": "string" },
        "category": { "$ref": "#/definitions/IssueCategory" },
        "status": {
          "type": "string",
          "enum": ["found", "not_applicable"]
        },
        "severity": { "$ref": "#/definitions/IssueSeverity" },
        "evidence_type": {
          "type": "string",
          "enum": [
            "explicit_conflict",
            "explicit_omission",
            "semantic_inference",
            "stylistic_judgment"
          ]
        },
        "scenario_assumption": {
          "type": "string",
          "enum": ["inferred_from_text", "user_provided", "worst_case_default"]
        },
        "not_applicable_reason": { "type": "string" },
        "execution_mode": {
          "type": "string",
          "enum": ["static_check", "llm_judge", "hybrid"]
        },
        "domain_specific": { "type": "boolean" },
        "consensus": {
          "type": "string",
          "enum": ["confirmed", "single_model_flag", "static_check_deterministic"]
        },
        "vote": {
          "type": "object",
          "required": ["models_flagged", "models_passed"],
          "additionalProperties": false,
          "properties": {
            "models_flagged": { "type": "array", "items": { "type": "string" } },
            "models_passed": { "type": "array", "items": { "type": "string" } }
          }
        },
        "location": {
          "type": "object",
          "required": ["anchor_before", "anchor_after", "ambiguous"],
          "additionalProperties": false,
          "properties": {
            "anchor_before": { "type": "string" },
            "anchor_after": { "type": "string" },
            "matched_text": { "type": "string" },
            "line_range": {
              "type": "array",
              "items": { "type": "integer" },
              "minItems": 2,
              "maxItems": 2
            },
            "ambiguous": { "type": "boolean" }
          }
        },
        "description": { "type": "string", "minLength": 1 },
        "fix": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/definitions/Fix" }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "found" } },
            "required": ["status"]
          },
          "then": {
            "required": ["severity", "evidence_type", "scenario_assumption"]
          }
        },
        {
          "if": {
            "properties": { "status": { "const": "not_applicable" } },
            "required": ["status"]
          },
          "then": {
            "required": ["not_applicable_reason"]
          }
        }
      ]
    },
    "IssueCategory": {
      "type": "string",
      "enum": [
        "clarity",
        "contract",
        "resource",
        "interop",
        "robustness",
        "quality",
        "compliance"
      ]
    },
    "IssueSeverity": {
      "type": "string",
      "enum": ["critical", "major", "minor", "info"]
    },
    "Fix": {
      "type": "object",
      "required": ["action", "fix_requires_review"],
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "text_replace",
            "text_insert",
            "text_delete",
            "config_change",
            "constraint_removal",
            "constraint_add",
            "schema_add_field",
            "reorder_section"
          ]
        },
        "target": { "type": "string" },
        "from": {},
        "to": {},
        "content": { "type": "string" },
        "fix_requires_review": { "type": "boolean", "const": true }
      }
    }
  }
}
