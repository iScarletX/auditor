{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://butler.local/schemas/review-report.schema.json",
  "title": "ReviewReport",
  "type": "object",
  "required": [
    "meta",
    "document_profile",
    "prescription",
    "incomplete_checks",
    "issues",
    "raw_model_outputs",
    "summary",
    "check_plan"
  ],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "target_sp_hash",
        "review_id",
        "skills_run",
        "models_used",
        "expected_skill_model_calls",
        "actual_skill_model_calls",
        "consolidation_model",
        "consolidation_model_source",
        "timestamp",
        "scenario_hint"
      ],
      "additionalProperties": false,
      "properties": {
        "review_id": {
          "type": "string"
        },
        "target_sp_hash": {
          "type": "string"
        },
        "skills_run": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "models_used": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expected_skill_model_calls": {
          "type": "integer",
          "minimum": 0
        },
        "actual_skill_model_calls": {
          "type": "integer",
          "minimum": 0
        },
        "consolidation_model": {
          "type": "string"
        },
        "consolidation_model_source": {
          "type": "string",
          "enum": [
            "auto_selected",
            "user_specified"
          ]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "review_duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "scenario_hint": {
          "type": "string"
        },
        "degraded": {
          "const": true
        },
        "degraded_reason": {
          "type": "string"
        },
        "degraded_stage": {
          "type": "string"
        }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/IssueGroup"
      }
    },
    "document_profile": {
      "$ref": "#/definitions/DocumentProfile"
    },
    "prescription": {
      "$ref": "#/definitions/ReviewPrescription"
    },
    "incomplete_checks": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/IncompleteCheck"
      }
    },
    "raw_model_outputs": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/RawModelOutput"
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "overall_score",
        "issue_count_by_severity",
        "issue_count_by_category"
      ],
      "additionalProperties": false,
      "properties": {
        "overall_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "issue_count_by_severity": {
          "type": "object",
          "required": [
            "严重",
            "中等",
            "轻微"
          ],
          "additionalProperties": false,
          "properties": {
            "严重": {
              "type": "integer",
              "minimum": 0
            },
            "中等": {
              "type": "integer",
              "minimum": 0
            },
            "轻微": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "issue_count_by_category": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "clarity": {
              "type": "integer",
              "minimum": 0
            },
            "contract": {
              "type": "integer",
              "minimum": 0
            },
            "resource": {
              "type": "integer",
              "minimum": 0
            },
            "interop": {
              "type": "integer",
              "minimum": 0
            },
            "robustness": {
              "type": "integer",
              "minimum": 0
            },
            "quality": {
              "type": "integer",
              "minimum": 0
            },
            "compliance": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "check_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "skill_id",
          "skill_title",
          "decision",
          "reason"
        ],
        "properties": {
          "skill_id": {
            "type": "string"
          },
          "skill_title": {
            "type": "string"
          },
          "decision": {
            "enum": [
              "run",
              "skip"
            ]
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "fix_plans": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "action_priority",
          "apply_mode",
          "edits"
        ],
        "properties": {
          "action_priority": {
            "type": "number"
          },
          "apply_mode": {
            "enum": [
              "independent",
              "group"
            ]
          },
          "group_note": {
            "type": "string"
          },
          "edits": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "before_text",
                "after_text",
                "note"
              ],
              "properties": {
                "before_text": {
                  "type": "string"
                },
                "after_text": {
                  "type": "string"
                },
                "note": {
                  "type": "string"
                }
              }
            }
          },
          "no_fix_reason": {
            "type": "string"
          },
          "confidence_caveat": {
            "const": true
          }
        }
      }
    }
  },
  "definitions": {
    "IncompleteCheck": {
      "type": "object",
      "required": [
        "skill_id",
        "skill_title",
        "expected_model_ids",
        "failed_model_ids",
        "error_messages"
      ],
      "additionalProperties": false,
      "properties": {
        "skill_id": {
          "type": "string"
        },
        "skill_title": {
          "type": "string"
        },
        "expected_model_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failed_model_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "error_messages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "DocumentProfile": {
      "type": "object",
      "required": [
        "document_purpose",
        "output_consumer",
        "declared_exclusions",
        "internal_conventions",
        "interaction_mode",
        "confidence_note"
      ],
      "additionalProperties": false,
      "properties": {
        "document_purpose": {
          "type": "string",
          "minLength": 1
        },
        "output_consumer": {
          "type": "string",
          "minLength": 1
        },
        "declared_exclusions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "internal_conventions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "interaction_mode": {
          "type": "string",
          "enum": [
            "single_turn",
            "multi_turn",
            "unknown"
          ]
        },
        "confidence_note": {
          "type": "string"
        },
        "structural_patterns": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "gate_rules",
              "numbered_checklist",
              "multi_step_pipeline",
              "enum_or_forbidden_list",
              "cross_file_reference",
              "unclassified"
            ]
          }
        }
      }
    },
    "ReviewPrescription": {
      "type": "object",
      "required": [
        "overall_assessment",
        "priority_actions",
        "minor_notes",
        "revised_document_available",
        "revised_document_diff_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "overall_assessment": {
          "type": "string",
          "minLength": 1
        },
        "priority_actions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/PrescriptionPriorityAction"
          }
        },
        "minor_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "revised_document_available": {
          "type": "boolean"
        },
        "revised_document_diff_summary": {
          "type": "string"
        },
        "revised_document_after": {
          "type": "string"
        }
      }
    },
    "PrescriptionPriorityAction": {
      "type": "object",
      "required": [
        "priority",
        "action_summary",
        "why",
        "related_issue_ids",
        "conflicts_resolved"
      ],
      "additionalProperties": false,
      "properties": {
        "priority": {
          "type": "integer",
          "minimum": 1
        },
        "action_summary": {
          "type": "string",
          "minLength": 1
        },
        "why": {
          "type": "string",
          "minLength": 1
        },
        "related_issue_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "conflicts_resolved": {
          "type": "string"
        },
        "nature": {
          "enum": [
            "wording",
            "flow",
            "engineering",
            "safety"
          ]
        },
        "grouping_logic": {
          "type": "string"
        },
        "position_relation": {
          "enum": [
            "joint",
            "independent"
          ]
        }
      }
    },
    "IssueGroup": {
      "type": "object",
      "required": [
        "id",
        "merge_type",
        "title",
        "category",
        "severity_display",
        "confidence_display",
        "locations",
        "description",
        "fix_items",
        "related_skill_ids",
        "domain_specific"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "merge_type": {
          "type": "string",
          "enum": [
            "single",
            "same_skill_multi_location",
            "duplicate_content_merge",
            "systemic_synthesis",
            "cross_skill_same_location"
          ]
        },
        "title": {
          "type": "string"
        },
        "related_skill_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "category": {
          "type": "string",
          "enum": [
            "clarity",
            "contract",
            "resource",
            "interop",
            "robustness",
            "quality",
            "compliance"
          ]
        },
        "severity_display": {
          "type": "string",
          "enum": [
            "严重",
            "中等",
            "轻微"
          ]
        },
        "confidence_display": {
          "type": "string",
          "enum": [
            "高",
            "中",
            "仅供参考"
          ]
        },
        "domain_specific": {
          "type": "boolean"
        },
        "locations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "marker_index",
              "anchor_before",
              "anchor_after",
              "ambiguous"
            ],
            "additionalProperties": false,
            "properties": {
              "marker_index": {
                "type": "integer"
              },
              "anchor_before": {
                "type": "string"
              },
              "anchor_after": {
                "type": "string"
              },
              "matched_text": {
                "type": "string"
              },
              "ambiguous": {
                "type": "boolean"
              },
              "source_issue_id": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            }
          }
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "raw_model_output_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "profile_conflict": {
          "type": "boolean",
          "const": true
        },
        "profile_conflict_detail": {
          "type": "string"
        },
        "fix_items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "marker_index",
              "fix",
              "fix_requires_review"
            ],
            "additionalProperties": false,
            "properties": {
              "marker_index": {
                "type": "integer"
              },
              "fix": {
                "oneOf": [
                  {
                    "type": "null"
                  },
                  {
                    "$ref": "#/definitions/Fix"
                  }
                ]
              },
              "fix_requires_review": {
                "type": "boolean",
                "const": true
              }
            }
          }
        }
      }
    },
    "RawModelOutput": {
      "type": "object",
      "required": [
        "id",
        "review_id",
        "phase",
        "model_id",
        "attempt",
        "schema_name",
        "created_at",
        "raw_response_text"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "review_id": {
          "type": "string"
        },
        "phase": {
          "type": "string",
          "enum": [
            "document_profile",
            "skill_check",
            "consolidation_b1",
            "consolidation_b2",
            "fix_plan"
          ]
        },
        "skill_id": {
          "type": "string"
        },
        "skill_title": {
          "type": "string"
        },
        "model_id": {
          "type": "string"
        },
        "attempt": {
          "type": "integer",
          "minimum": 1
        },
        "schema_name": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "raw_response_text": {
          "type": "string"
        },
        "extracted_content": {
          "type": "string"
        }
      }
    },
    "Fix": {
      "type": "object",
      "required": [
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "text_replace",
            "text_insert",
            "text_delete",
            "config_change",
            "constraint_removal",
            "constraint_add",
            "schema_add_field",
            "reorder_section"
          ]
        },
        "target": {
          "type": "string"
        },
        "from": {},
        "to": {},
        "content": {
          "type": "string"
        }
      }
    }
  }
}
